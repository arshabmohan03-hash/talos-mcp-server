{
  "name": "talos-mcp-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Talos MCP server exposing the AI brute-force detector and security tools",
  "scripts": {
    "dev": "nitrostack-cli dev",
    "build": "nitrostack-cli build",
    "build:deploy": "npm run install:python && npm run build",
    "start": "npm run build && nitrostack-cli start",
    "start:prod": "nitrostack-cli start",
    "start:node": "node dist/index.js",
    "prepare:standalone": "node scripts/prepare-standalone.cjs",
    "embed:test-keys": "node scripts/embed-test-keys.cjs",
    "install:python": "node scripts/install-python-deps.cjs",
    "upgrade": "nitrostack-cli upgrade",
    "install:all": "nitrostack-cli install",
    "widget": "npm --prefix src/widgets"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": ">=0.1.0",
    "@nitrostack/core": "^1.0.13",
    "@types/nodemailer": "^8.0.1",
    "dotenv": "^16.3.1",
    "nodemailer": "^9.0.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@nitrostack/cli": "^1.0.14",
    "@types/node": "^22.10.0",
    "typescript": "^5.3.3"
  },
  "author": "Talos",
  "nitrostack": {
    "skillsVersion": "1.0.0"
  }
}
